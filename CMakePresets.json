{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_EXTENSIONS": "Off"
      }
    },
    {
      "name": "GPU",
      "displayName": "GCC GPU Settings",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "/leonardo/home/userexternal/rmario00/Trilinos-trilinos-release-16-1-0/install/bin/nvcc_wrapper",
        "Trilinos_DIR": "/leonardo/home/userexternal/rmario00/Trilinos-trilinos-release-16-1-0/install/lib/cmake/Trilinos",
        "USE_CUDA": "ON"
      }
    },
    {
      "name": "CPU",
      "displayName": "GCC CPU — Trilinos 16",
      "inherits": "common",
      "cacheVariables": {
        "USE_CUDA": "OFF",
        "Trilinos_DIR": "/home/mraeth@ipp.mpg.de/phd/codes/trilinos16/Trilinos-trilinos-release-16-1-0/install/lib/cmake/Trilinos"
      }
    },
    {
      "name": "CPU-T17",
      "displayName": "GCC CPU — Trilinos 17 / Kokkos 5.0.2 / C++20",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "USE_CUDA": "OFF",
        "Kokkos_ROOT": "${sourceDir}/trilinos_install/kokkos-install",
        "Trilinos_DIR": "${sourceDir}/trilinos_install/trilinos-install/lib/cmake/Trilinos"
      }
    }
  ]
}
